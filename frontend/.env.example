# API base URL for the frontend (optional)
# - Omit or use /api for dev (uses Vite proxy to backend)
# - Use full URL for production, e.g. https://api.yourdomain.com/api
# VITE_API_BASE_URL=/api

# Backend URL for Vite dev proxy (when using /api)
# VITE_API_PROXY_TARGET=http://localhost:5000

# Dev server port (default 5173)
# VITE_DEV_PORT=5173

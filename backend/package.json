{
  "name": "hrm-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon --exec \"ts-node --transpile-only\" src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node --transpile-only src/seed.ts",
    "seed:prod": "node dist/seed.js",
    "db:push": "prisma db push --skip-generate",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.17.2",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.0",
    "@types/node": "^25.4.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}

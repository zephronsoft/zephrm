# HRM Docker Environment
# Copy to .env and customize for production

# Backend
JWT_SECRET=change_me_to_a_strong_random_secret_in_production
JWT_EXPIRES_IN=7d

# Ports (optional - defaults: 5000 backend, 80 frontend)
BACKEND_PORT=5000
FRONTEND_PORT=80

# CORS - comma-separated origins when frontend/backend on different hosts
# CORS_ORIGIN=http://localhost,https://hrm.yourdomain.com
